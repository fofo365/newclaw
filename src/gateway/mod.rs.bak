// 请求/响应类型

#[derive(Debug, Deserialize)]
pub struct ChatRequestJson {
    pub message: String,
    pub session_id: Option<String>,
}

#[derive(Debug, Serialize)]
pub struct ChatResponseJson {
    pub response: String,
    pub session_id: String,
    pub model: String,
    pub tokens_used: Option<usize>,
}

// TODO: 重新实现工具执行请求类型
